# Copy this file to .env and fill in your values

# The deployed registry contract ID on Stellar testnet
REGISTRY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your Stellar secret key (keep this private! never commit to git)
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stellar RPC endpoint (default is testnet)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Set to "mainnet" to use the public network
STELLAR_NETWORK=testnet
